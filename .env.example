# MT-Cotiza Client Run - launcher only
MT_ARTIFACT_ONLY=1
MT_FAST_START=1
MT_FORCE_REBUILD=0
MT_CLEAN_DATA=0
RUN_DB_MODE=docker

# Ports
API_PORT=8080
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Spring profile
API_PROFILE=prod
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Database managed by Run at runtime
# RUN_DB_MODE=docker stores PostgreSQL files in data/db through docker-compose.
POSTGRES_DB=cotiflow
POSTGRES_USER=cotiflow_user
POSTGRES_PASSWORD=cotiflow_password
POSTGRES_PORT=5434
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/cotiflow
SPRING_DATASOURCE_USERNAME=cotiflow_user
SPRING_DATASOURCE_PASSWORD=cotiflow_password

# Security / integrations
JWT_SECRET_KEY=change-this-secret-before-production
SERVER_SYNC_SECRET=
SERVER_SYNC_USERS_URL=https://telemetriaperu.com:3021/api/server-sync/users
SERVER_SYNC_TASKS_URL=https://telemetriaperu.com:3021/api/server-sync/tasks
SERVER_SYNC_TASKS_PAGE_URL=https://telemetriaperu.com:3021/api/server-sync/tasks/page
SERVER_SYNC_QUOTATION_REQUESTS_URL=https://telemetriaperu.com:3021/api/server-sync/quotation-requests
SERVER_SYNC_TECHNICAL_REPORTS_URL=https://telemetriaperu.com:3021/api/server-sync/technical-reports/pending

# Local storage/logs
# These are forced by the launcher to absolute paths inside MT-Client-Run/data.
UPLOAD_DIR=./data/uploads
LOG_FILE_NAME=./data/logs/cotiflow.log
